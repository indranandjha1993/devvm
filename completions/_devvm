#compdef devvm

_devvm() {
  local -a commands
  commands=(
    'init:Create VM and install everything'
    'start:Start VM or a specific stack'
    'stop:Stop VM or a specific stack'
    'restart:Restart VM or a specific stack'
    'reset:Rebuild VM or reset a stack to defaults'
    'destroy:Delete VM permanently'
    'logs:Tail logs for any stack or app'
    'ssh:Shell into VM'
    'run:Run command in VM'
    'exec:Run command as root in VM'
    'open:Open web UI in browser'
    'status:Show status of all services'
    'debug:Start remote debugger'
    'db:Connect to database'
    'creds:Manage database credentials'
    'app:Manage hosted applications'
    'ports:Show port map'
    'verify:Run health check'
    'version:Show version'
    'help:Show help'
  )

  _arguments -C \
    '1:command:->command' \
    '*::arg:->args'

  case "$state" in
    command)
      _describe 'command' commands
      ;;
    args)
      case "${words[1]}" in
        start|stop|restart|reset|logs)
          _values 'stack' mysql postgres redis nginx grafana prometheus loki tempo promtail cadvisor obs
          ;;
        debug)
          _values 'language' python node php go java
          ;;
        db)
          _values 'database' mysql psql redis
          ;;
        open)
          _values 'ui' grafana adminer prometheus loki tempo
          ;;
        creds)
          _values 'action' list show set reset
          ;;
        app)
          _values 'action' add remove list create
          ;;
      esac
      ;;
  esac
}

_devvm "$@"
