#!/bin/bash
# devvm - Developer VM manager for OrbStack
# https://github.com/indranandjha/dev-vm
set -euo pipefail

readonly VERSION="1.0.0"
readonly VM_NAME="dev"
readonly VM_TARGET="/opt/dev-vm"
readonly OBS_COMPOSE="$VM_TARGET/observability/docker-compose.yml"
readonly HOST="dev.orb.local"

# ── Colors ────────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  readonly R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m' C='\033[0;36m'
  readonly B='\033[1m' D='\033[2m' N='\033[0m'
else
  readonly R='' G='' Y='' C='' B='' D='' N=''
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

die()  { echo -e "${R}Error: $*${N}" >&2; exit 1; }
info() { echo -e "${C}$*${N}"; }
ok()   { echo -e "${G}$*${N}"; }
warn() { echo -e "${Y}$*${N}"; }

vm_exists() { orb list 2>/dev/null | grep -q "$VM_NAME"; }
vm_running() { orb list 2>/dev/null | grep -q "$VM_NAME.*running"; }

ensure_orb() {
  command -v orb &>/dev/null || die "OrbStack is not installed. Get it at https://orbstack.dev"
}

ensure_exists() {
  vm_exists || die "VM '$VM_NAME' does not exist. Run 'devvm init' first."
}

ensure_running() {
  ensure_exists
  if ! vm_running; then
    warn "VM is stopped. Starting..."
    orb start "$VM_NAME"
    sleep 2
  fi
}

vm()      { orb -m "$VM_NAME" "$@"; }
vm_sudo() { orb -m "$VM_NAME" sudo "$@"; }

svc_status() {
  local name="$1"
  local status
  status=$(vm_sudo systemctl is-active "$name" 2>/dev/null) || status="inactive"
  echo "$status"
}

dot() {
  local status="$1" name="$2"
  if [[ "$status" == "active" || "$status" == "running" ]]; then
    echo -e "  ${G}●${N} $name"
  else
    echo -e "  ${R}●${N} $name ($status)"
  fi
}

# ── Machine Lifecycle ─────────────────────────────────────────────────────────

cmd_init() {
  ensure_orb
  local config="${1:-}"

  if vm_exists; then
    warn "VM '$VM_NAME' already exists."
    read -rp "Recreate from scratch? This deletes all data. (yes/no): " ans
    [[ "$ans" == "yes" ]] || { echo "Aborted."; return; }
    orb delete "$VM_NAME" -f 2>/dev/null || true
    sleep 2
  fi

  # Locate cloud-init config
  local ci_file=""
  if [[ -n "$config" && -f "$config" ]]; then
    ci_file="$config"
  else
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    for candidate in \
      "$script_dir/../cloud-init/user-data.yaml" \
      "${DEVVM_HOME:-$HOME/.devvm}/cloud-init/user-data.yaml"; do
      [[ -f "$candidate" ]] && ci_file="$candidate" && break
    done
  fi

  info "Creating Ubuntu VM '$VM_NAME'..."
  if [[ -n "$ci_file" ]]; then
    info "Using cloud-init: $ci_file"
    orb create ubuntu "$VM_NAME" -c "$ci_file"
  else
    warn "No cloud-init config found. Creating bare VM."
    orb create ubuntu "$VM_NAME"
  fi

  ok "VM created. Run 'devvm provision' to install stacks, or 'devvm up' to start."
}

cmd_provision() {
  ensure_running

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local project_root="$script_dir/.."

  # Check if provision files exist locally
  if [[ ! -d "$project_root/provision" ]]; then
    die "Provision scripts not found at $project_root/provision"
  fi

  info "Waiting for cloud-init..."
  vm_sudo cloud-init status --wait 2>/dev/null || true

  info "Pushing files to VM..."
  vm_sudo mkdir -p "$VM_TARGET"
  vm_sudo chmod 777 "$VM_TARGET"

  for dir in provision observability systemd; do
    [[ -d "$project_root/$dir" ]] || continue
    vm_sudo mkdir -p "$VM_TARGET/$dir"
    vm_sudo chmod 777 "$VM_TARGET/$dir"
    for f in "$project_root/$dir"/*; do
      [[ -f "$f" ]] && vm_sudo bash -c "cat > $VM_TARGET/$dir/$(basename "$f")" < "$f"
    done
    # Handle subdirectories (observability has nested dirs)
    find "$project_root/$dir" -mindepth 2 -type f 2>/dev/null | while read -r f; do
      local rel="${f#$project_root/$dir/}"
      local rdir="$(dirname "$rel")"
      vm_sudo mkdir -p "$VM_TARGET/$dir/$rdir"
      vm_sudo bash -c "cat > $VM_TARGET/$dir/$rel" < "$f"
    done
  done
  [[ -f "$project_root/verify.sh" ]] && vm_sudo bash -c "cat > $VM_TARGET/verify.sh" < "$project_root/verify.sh"

  vm_sudo chown -R root:root "$VM_TARGET"
  vm_sudo find "$VM_TARGET" -name "*.sh" -exec chmod +x {} \;

  info "Running provisioning..."
  vm_sudo bash "$VM_TARGET/provision/post-init.sh"

  info "Installing exporters..."
  vm_sudo bash "$VM_TARGET/provision/install-exporters.sh" 2>/dev/null || warn "Exporters install had issues (may need retry)"

  info "Installing systemd services..."
  vm_sudo bash -c 'cp '"$VM_TARGET"'/systemd/*.service /etc/systemd/system/ 2>/dev/null; systemctl daemon-reload' || true
  for svc in node-exporter adminer mysqld-exporter postgres-exporter redis-exporter; do
    vm_sudo systemctl enable --now "$svc" 2>/dev/null || true
  done

  info "Starting observability stack..."
  vm_sudo docker compose -f "$OBS_COMPOSE" up -d 2>/dev/null || warn "Docker compose failed (try 'devvm obs up')"

  ok "Provisioning complete."
  echo ""
  cmd_status
}

cmd_up() {
  ensure_orb
  ensure_exists

  if vm_running; then
    ok "VM is already running."
    return
  fi

  info "Starting VM..."
  orb start "$VM_NAME"
  sleep 2

  # Start observability if compose exists
  if vm bash -c "test -f $OBS_COMPOSE" 2>/dev/null; then
    info "Starting observability stack..."
    vm_sudo docker compose -f "$OBS_COMPOSE" up -d 2>/dev/null || true
  fi

  ok "VM is running."
}

cmd_down() {
  ensure_exists
  if ! vm_running; then
    warn "VM is already stopped."
    return
  fi
  warn "Stopping VM..."
  orb stop "$VM_NAME"
  ok "VM stopped."
}

cmd_restart() {
  ensure_exists
  warn "Restarting VM..."
  orb stop "$VM_NAME" 2>/dev/null || true
  sleep 1
  orb start "$VM_NAME"
  sleep 2

  if vm bash -c "test -f $OBS_COMPOSE" 2>/dev/null; then
    info "Starting observability stack..."
    vm_sudo docker compose -f "$OBS_COMPOSE" up -d 2>/dev/null || true
  fi

  ok "VM restarted."
}

cmd_reboot() {
  ensure_running
  warn "Rebooting VM (graceful)..."
  vm_sudo reboot 2>/dev/null || true
  sleep 3

  local tries=0
  while ! vm_running && (( tries < 20 )); do
    sleep 1
    (( tries++ ))
  done

  if vm_running; then
    ok "VM rebooted."
  else
    warn "VM not yet running. It may still be booting."
  fi
}

cmd_stop() {
  cmd_down "$@"
}

cmd_ssh() {
  ensure_running
  if [[ $# -gt 0 ]]; then
    vm "$@"
  else
    vm
  fi
}

cmd_destroy() {
  ensure_exists
  echo -e "${R}${B}WARNING: This permanently deletes the VM and ALL its data.${N}"
  echo -e "${R}Databases, configs, and observability data will be lost.${N}"
  read -rp "Type 'destroy' to confirm: " ans
  [[ "$ans" == "destroy" ]] || { echo "Aborted."; return; }
  orb delete "$VM_NAME" -f
  ok "VM destroyed."
}

# ── Status ────────────────────────────────────────────────────────────────────

cmd_status() {
  ensure_orb

  if ! vm_exists; then
    echo -e "${R}VM '$VM_NAME' does not exist. Run 'devvm init' to create.${N}"
    return
  fi

  echo -e "${B}DevVM${N} v${VERSION}"
  echo ""

  if ! vm_running; then
    echo -e "  State: ${R}stopped${N}"
    echo ""
    echo "  Run 'devvm up' to start."
    return
  fi

  echo -e "  State: ${G}running${N}"
  echo ""

  echo -e "${B}Databases${N}"
  for svc in mysql postgresql redis-server; do
    dot "$(svc_status "$svc")" "$svc"
  done

  echo ""
  echo -e "${B}Exporters${N}"
  for svc in node-exporter mysqld-exporter postgres-exporter redis-exporter; do
    dot "$(svc_status "$svc")" "$svc"
  done

  echo ""
  echo -e "${B}Observability${N}"
  for ctr in grafana prometheus loki tempo promtail cadvisor; do
    local st
    st=$(vm docker inspect -f '{{.State.Status}}' "$ctr" 2>/dev/null) || st="not found"
    dot "$st" "$ctr"
  done

  echo ""
  echo -e "${B}Demo Apps${N}"
  for svc in demo-node demo-python demo-php; do
    dot "$(svc_status "$svc")" "$svc"
  done

  echo ""
  cmd_ports
}

# ── Service Management ────────────────────────────────────────────────────────

cmd_service() {
  ensure_running
  local action="${1:-}" name="${2:-}"

  [[ -n "$action" && -n "$name" ]] || {
    echo "Usage: devvm service <start|stop|restart|status|logs> <name>"
    echo ""
    echo "Examples:"
    echo "  devvm service restart mysql"
    echo "  devvm service logs demo-node"
    echo "  devvm service stop demo-python"
    return
  }

  case "$action" in
    start|stop|restart)
      vm_sudo systemctl "$action" "$name"
      ok "$name: $action done"
      ;;
    status)
      vm_sudo systemctl status "$name" --no-pager -l
      ;;
    logs)
      vm_sudo journalctl -u "$name" --no-pager -f
      ;;
    *)
      die "Unknown action: $action (use start|stop|restart|status|logs)"
      ;;
  esac
}

# ── Observability ─────────────────────────────────────────────────────────────

cmd_obs() {
  ensure_running
  local action="${1:-status}"
  shift 2>/dev/null || true

  case "$action" in
    up|start)
      info "Starting observability stack..."
      vm_sudo docker compose -f "$OBS_COMPOSE" up -d
      ok "Observability running."
      echo "  Grafana:    http://$HOST:3000"
      echo "  Prometheus: http://$HOST:9090"
      ;;
    down|stop)
      warn "Stopping observability stack..."
      vm_sudo docker compose -f "$OBS_COMPOSE" down
      ok "Stopped."
      ;;
    restart)
      vm_sudo docker compose -f "$OBS_COMPOSE" restart "$@"
      ok "Restarted."
      ;;
    logs)
      if [[ $# -gt 0 ]]; then
        vm_sudo docker compose -f "$OBS_COMPOSE" logs -f "$@"
      else
        vm_sudo docker compose -f "$OBS_COMPOSE" logs -f --tail=50
      fi
      ;;
    status)
      for ctr in grafana prometheus loki tempo promtail cadvisor; do
        local st
        st=$(vm docker inspect -f '{{.State.Status}}' "$ctr" 2>/dev/null) || st="not found"
        dot "$st" "$ctr"
      done
      ;;
    *)
      echo "Usage: devvm obs <up|down|restart|logs|status> [service]"
      ;;
  esac
}

# ── Open UIs ──────────────────────────────────────────────────────────────────

cmd_open() {
  local target="${1:-grafana}"
  local url=""

  case "$target" in
    grafana)    url="http://$HOST:3000" ;;
    adminer)    url="http://$HOST:8080" ;;
    prometheus) url="http://$HOST:9090" ;;
    loki)       url="http://$HOST:3100" ;;
    tempo)      url="http://$HOST:3200" ;;
    *)          die "Unknown UI: $target (grafana|adminer|prometheus|loki|tempo)" ;;
  esac

  info "Opening $url"
  open "$url"
}

# ── Debugging ─────────────────────────────────────────────────────────────────

cmd_debug() {
  ensure_running
  local lang="${1:-}"
  shift 2>/dev/null || true

  case "$lang" in
    python|py)
      info "debugpy on :5678 — attach VS Code 'Python: Remote Attach (dev VM)'"
      vm python-debug "$@"
      ;;
    node|js)
      info "Inspector on :9229 — attach VS Code 'Node: Remote Attach (dev VM)'"
      vm node-debug "$@"
      ;;
    php)
      echo -e "${C}Xdebug (trigger mode) on :9003${N}"
      echo ""
      echo "  Browser: add ?XDEBUG_TRIGGER=1 to URL"
      echo "  CLI:     XDEBUG_TRIGGER=1 php script.php"
      echo "  VS Code: use 'PHP: Xdebug (dev VM)' launch config"
      ;;
    go)
      info "Delve on :2345 — attach VS Code 'Go: Remote Attach (dev VM)'"
      vm go-debug "$@"
      ;;
    java)
      info "JDWP on :5005 — attach VS Code 'Java: Remote Attach (dev VM)'"
      vm java-debug "$@"
      ;;
    *)
      echo "Usage: devvm debug <language> [script] [args...]"
      echo ""
      echo "  python <file>   debugpy on :5678"
      echo "  node   <file>   Inspector on :9229"
      echo "  php             Xdebug instructions (:9003)"
      echo "  go     [pkg]    Delve on :2345"
      echo "  java   <class>  JDWP on :5005"
      ;;
  esac
}

# ── Databases ─────────────────────────────────────────────────────────────────

cmd_db() {
  ensure_running
  local db="${1:-}"
  shift 2>/dev/null || true

  case "$db" in
    mysql)          vm mysql -u dev -pdev "$@" ;;
    psql|postgres)  vm psql -U dev devdb "$@" ;;
    redis)          vm redis-cli "$@" ;;
    *)
      echo "Usage: devvm db <mysql|psql|redis> [args...]"
      echo ""
      echo "  mysql     dev:dev@:3306"
      echo "  psql      dev:dev@:5432/devdb"
      echo "  redis     :6379 (no auth)"
      ;;
  esac
}

# ── Run command in VM ─────────────────────────────────────────────────────────

cmd_run() {
  ensure_running
  [[ $# -gt 0 ]] || die "Usage: devvm run <command> [args...]"
  vm "$@"
}

cmd_exec() {
  ensure_running
  [[ $# -gt 0 ]] || die "Usage: devvm exec <command> [args...]"
  vm_sudo "$@"
}

# ── Ports ─────────────────────────────────────────────────────────────────────

cmd_ports() {
  echo -e "${B}Services${N}  (accessible at $HOST)"
  printf "  ${D}%-18s %-6s %s${N}\n" "NAME" "PORT" "ACCESS"
  printf "  %-18s %-6s %s\n" "Grafana"      3000 "http://$HOST:3000"
  printf "  %-18s %-6s %s\n" "Prometheus"   9090 "http://$HOST:9090"
  printf "  %-18s %-6s %s\n" "Loki"         3100 "http://$HOST:3100"
  printf "  %-18s %-6s %s\n" "Tempo"        3200 "grpc://$HOST:4317"
  printf "  %-18s %-6s %s\n" "Adminer"      8080 "http://$HOST:8080"
  printf "  %-18s %-6s %s\n" "MySQL"        3306 "dev/dev"
  printf "  %-18s %-6s %s\n" "PostgreSQL"   5432 "dev/dev (db: devdb)"
  printf "  %-18s %-6s %s\n" "Redis"        6379 "(no auth)"
  echo ""
  echo -e "${B}Debuggers${N}"
  printf "  ${D}%-18s %-6s %s${N}\n" "NAME" "PORT" "DIRECTION"
  printf "  %-18s %-6s %s\n" "Xdebug"       9003 "VM -> Mac"
  printf "  %-18s %-6s %s\n" "debugpy"      5678 "Mac -> VM"
  printf "  %-18s %-6s %s\n" "Node inspect" 9229 "Mac -> VM"
  printf "  %-18s %-6s %s\n" "Delve"        2345 "Mac -> VM"
  printf "  %-18s %-6s %s\n" "JDWP"         5005 "Mac -> VM"
}

# ── Verify ────────────────────────────────────────────────────────────────────

cmd_verify() {
  ensure_running
  vm_sudo bash "$VM_TARGET/verify.sh"
}

# ── Version ───────────────────────────────────────────────────────────────────

cmd_version() {
  echo "devvm $VERSION"
}

# ── Help ──────────────────────────────────────────────────────────────────────

cmd_help() {
  cat <<EOF
${B}devvm${N} v${VERSION} — Developer VM manager for OrbStack

${B}USAGE${N}
  devvm <command> [args...]

${B}MACHINE${N}
  init [cloud-init.yaml]   Create the VM (optionally with cloud-init config)
  provision                Install all stacks, databases, observability
  up                       Start VM + observability
  down | stop              Stop VM
  restart                  Stop and start VM
  reboot                   Graceful reboot (keeps data)
  destroy                  Delete VM and all data

${B}ACCESS${N}
  ssh [command]            Shell into VM, or run a command
  run <cmd>                Run command in VM as user
  exec <cmd>               Run command in VM as root
  open <ui>                Open web UI (grafana|adminer|prometheus)

${B}SERVICES${N}
  status                   Show VM, services, and ports
  service <action> <name>  Manage systemd service (start|stop|restart|status|logs)
  obs <action> [service]   Manage observability (up|down|restart|logs|status)

${B}DEVELOP${N}
  debug <lang> [file]      Start remote debugger (python|node|php|go|java)
  db <engine> [args]       Connect to database (mysql|psql|redis)

${B}INFO${N}
  ports                    Show port map
  verify                   Run full health check
  version                  Show version
  help                     Show this help

${B}EXAMPLES${N}
  devvm up                         Start everything
  devvm ssh                        Open VM shell
  devvm db mysql                   Connect to MySQL
  devvm debug python app.py        Debug Python script
  devvm service restart mysql      Restart MySQL
  devvm obs logs grafana           Tail Grafana logs
  devvm open grafana               Open Grafana in browser
  devvm run node --version         Run command in VM
EOF
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)                 cmd_init "$@" ;;
    provision)            cmd_provision "$@" ;;
    up|start)             cmd_up "$@" ;;
    down|stop)            cmd_down "$@" ;;
    restart)              cmd_restart "$@" ;;
    reboot)               cmd_reboot "$@" ;;
    destroy)              cmd_destroy "$@" ;;
    ssh)                  cmd_ssh "$@" ;;
    run)                  cmd_run "$@" ;;
    exec)                 cmd_exec "$@" ;;
    open)                 cmd_open "$@" ;;
    status|st)            cmd_status "$@" ;;
    service|svc)          cmd_service "$@" ;;
    obs)                  cmd_obs "$@" ;;
    debug)                cmd_debug "$@" ;;
    db)                   cmd_db "$@" ;;
    ports)                cmd_ports "$@" ;;
    verify)               cmd_verify "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       cmd_help ;;
    *)
      die "Unknown command: $cmd\nRun 'devvm help' for usage."
      ;;
  esac
}

main "$@"
