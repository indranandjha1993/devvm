#!/bin/bash
# devvm - Developer VM manager for OrbStack
# https://github.com/indranandjha1993/devvm
set -euo pipefail

readonly VERSION="2.1.0"
readonly VM_NAME="dev"
readonly VM_TARGET="/opt/dev-vm"
readonly VM_CONFIG="$VM_TARGET/config"
readonly OBS_COMPOSE="$VM_TARGET/observability/docker-compose.yml"
readonly HOST="dev.orb.local"

# ── Colors ────────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  readonly R=$'\033[0;31m' G=$'\033[0;32m' Y=$'\033[1;33m' C=$'\033[0;36m'
  readonly B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
else
  readonly R='' G='' Y='' C='' B='' D='' N=''
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

die()  { echo -e "${R}Error: $*${N}" >&2; exit 1; }
info() { echo -e "${C}$*${N}"; }
ok()   { echo -e "${G}$*${N}"; }
warn() { echo -e "${Y}$*${N}"; }

vm_exists() { orb list 2>/dev/null | grep -q "$VM_NAME"; }
vm_running() { orb list 2>/dev/null | grep -q "$VM_NAME.*running"; }

ensure_orb() {
  command -v orb &>/dev/null || die "OrbStack is not installed. Get it at https://orbstack.dev"
}

ensure_exists() {
  vm_exists || die "VM '$VM_NAME' does not exist. Run 'devvm init' first."
}

ensure_running() {
  ensure_exists
  if ! vm_running; then
    warn "VM is stopped. Starting..."
    orb start "$VM_NAME"
    sleep 2
  fi
}

vm()      { orb -m "$VM_NAME" "$@"; }
vm_sudo() { orb -m "$VM_NAME" sudo "$@"; }

svc_status() {
  local name="$1"
  local status
  status=$(vm_sudo systemctl is-active "$name" 2>/dev/null) || status="inactive"
  echo "$status"
}

dot() {
  local status="$1" name="$2"
  if [[ "$status" == "active" || "$status" == "running" ]]; then
    echo -e "  ${G}●${N} $name"
  else
    echo -e "  ${R}●${N} $name ($status)"
  fi
}

# ── Known stacks (for targeted start/stop/restart/logs/reset) ─────────────────

# Maps user-facing names to systemd service or docker container names
_resolve_stack() {
  local name="$1"
  case "$name" in
    mysql)          echo "svc:mysql" ;;
    postgres|pg)    echo "svc:postgresql" ;;
    redis)          echo "svc:redis-server" ;;
    nginx)          echo "svc:nginx" ;;
    adminer)        echo "svc:adminer" ;;
    grafana)        echo "ctr:grafana" ;;
    prometheus)     echo "ctr:prometheus" ;;
    loki)           echo "ctr:loki" ;;
    tempo)          echo "ctr:tempo" ;;
    promtail)       echo "ctr:promtail" ;;
    cadvisor)       echo "ctr:cadvisor" ;;
    obs|observability) echo "obs" ;;
    app-*)          echo "svc:$name" ;;
    *)
      # Check if it's a registered app
      local apps_json app_type
      apps_json=$(vm_sudo cat "$VM_CONFIG/apps.json" 2>/dev/null) || apps_json='{}'
      app_type=$(echo "$apps_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('apps',{}).get('$name',{}).get('type',''))" 2>/dev/null) || app_type=""
      if [[ -n "$app_type" ]]; then
        if [[ "$app_type" == "static" ]]; then
          echo "static:$name"  # static apps are Nginx-only, no systemd
        else
          echo "svc:app-$name"
        fi
      else
        echo "svc:$name"  # try as raw systemd service
      fi
      ;;
  esac
}

_start_obs() {
  vm_sudo docker compose -f "$OBS_COMPOSE" up -d 2>/dev/null || true
}

_stop_obs() {
  vm_sudo docker compose -f "$OBS_COMPOSE" down 2>/dev/null || true
}

# ── Machine Lifecycle ─────────────────────────────────────────────────────────

cmd_init() {
  ensure_orb
  local config="${1:-}"

  if vm_exists; then
    warn "VM '$VM_NAME' already exists."
    read -rp "Recreate from scratch? This deletes all data. (yes/no): " ans
    [[ "$ans" == "yes" ]] || { echo "Aborted."; return; }
    orb delete "$VM_NAME" -f 2>/dev/null || true
    sleep 2
  fi

  # Locate cloud-init config
  local ci_file=""
  if [[ -n "$config" && -f "$config" ]]; then
    ci_file="$config"
  else
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    for candidate in \
      "$script_dir/../cloud-init/user-data.yaml" \
      "${DEVVM_HOME:-$HOME/.devvm}/cloud-init/user-data.yaml"; do
      [[ -f "$candidate" ]] && ci_file="$candidate" && break
    done
  fi

  info "Creating Ubuntu VM '$VM_NAME'..."
  if [[ -n "$ci_file" ]]; then
    orb create ubuntu "$VM_NAME" -c "$ci_file"
  else
    warn "No cloud-init config found. Creating bare VM."
    orb create ubuntu "$VM_NAME"
  fi

  ok "VM created. Provisioning..."
  echo ""

  # Auto-provision
  _provision
}

_provision() {
  ensure_running

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local project_root="$script_dir/.."

  [[ -d "$project_root/provision" ]] || die "Provision scripts not found at $project_root/provision"

  info "Waiting for cloud-init..."
  vm_sudo cloud-init status --wait 2>/dev/null || true

  info "Pushing files to VM..."
  vm_sudo mkdir -p "$VM_TARGET"
  vm_sudo chmod 777 "$VM_TARGET"

  for dir in provision observability systemd; do
    [[ -d "$project_root/$dir" ]] || continue

    # Push all files (including nested subdirectories)
    # Uses fd 3 for the file list to avoid conflicts with stdin redirection
    while IFS= read -r f <&3; do
      local rel="${f#$project_root/$dir/}"
      local rdir
      rdir="$(dirname "$rel")"
      vm_sudo mkdir -p "$VM_TARGET/$dir/$rdir"
      vm_sudo bash -c "cat > $VM_TARGET/$dir/$rel" < "$f"
    done 3< <(find "$project_root/$dir" -type f 2>/dev/null)
  done
  [[ -f "$project_root/verify.sh" ]] && vm_sudo bash -c "cat > $VM_TARGET/verify.sh" < "$project_root/verify.sh"

  vm_sudo chown -R root:root "$VM_TARGET"
  vm_sudo find "$VM_TARGET" -name "*.sh" -exec chmod +x {} \;

  info "[1/6] Installing languages..."
  vm_sudo bash "$VM_TARGET/provision/install-languages.sh"

  info "[2/6] Configuring databases..."
  vm_sudo bash "$VM_TARGET/provision/install-databases.sh"

  info "[3/6] Configuring debugging..."
  vm_sudo bash "$VM_TARGET/provision/configure-debugging.sh"

  info "[4/6] Installing tools..."
  vm_sudo bash "$VM_TARGET/provision/install-tools.sh"

  info "[5/6] Setting up config..."
  vm_sudo bash "$VM_TARGET/provision/setup-config.sh"

  info "[6/6] Installing Nginx..."
  vm_sudo bash "$VM_TARGET/provision/install-nginx.sh"

  info "Installing exporters..."
  vm_sudo bash "$VM_TARGET/provision/install-exporters.sh" 2>/dev/null || warn "Exporters install had issues (may need retry)"

  # Add user to docker group
  vm_sudo usermod -aG docker "$(vm whoami 2>/dev/null || echo indranandjha)" 2>/dev/null || true

  info "Enabling services..."
  vm_sudo bash -c 'cp '"$VM_TARGET"'/systemd/*.service /etc/systemd/system/ 2>/dev/null; systemctl daemon-reload' || true
  for svc in node-exporter adminer mysqld-exporter postgres-exporter redis-exporter; do
    vm_sudo systemctl enable --now "$svc" 2>/dev/null || true
  done

  info "Starting observability..."
  _start_obs

  ok "Ready."
  echo ""
  cmd_status
}

cmd_start() {
  ensure_orb
  local target="${1:-}"

  # No arg: start the whole VM
  if [[ -z "$target" ]]; then
    ensure_exists
    if vm_running; then
      ok "Already running."
      return
    fi
    info "Starting VM..."
    orb start "$VM_NAME"
    sleep 2
    _start_obs
    ok "VM is running."
    return
  fi

  # With arg: start a specific stack
  ensure_running
  local resolved
  resolved=$(_resolve_stack "$target")
  case "$resolved" in
    static:*) ok "$target is a static site (always served by Nginx)." ;;
    svc:*)    vm_sudo systemctl start "${resolved#svc:}"; ok "$target started." ;;
    ctr:*)    vm_sudo docker start "${resolved#ctr:}" 2>/dev/null; ok "$target started." ;;
    obs)      _start_obs; ok "Observability started." ;;
  esac
}

cmd_stop() {
  local target="${1:-}"

  # No arg: stop the whole VM
  if [[ -z "$target" ]]; then
    ensure_exists
    if ! vm_running; then
      warn "Already stopped."
      return
    fi
    warn "Stopping VM..."
    orb stop "$VM_NAME"
    ok "VM stopped."
    return
  fi

  # With arg: stop a specific stack
  ensure_running
  local resolved
  resolved=$(_resolve_stack "$target")
  case "$resolved" in
    static:*) ok "$target is a static site (always served by Nginx)." ;;
    svc:*)    vm_sudo systemctl stop "${resolved#svc:}"; ok "$target stopped." ;;
    ctr:*)    vm_sudo docker stop "${resolved#ctr:}" 2>/dev/null; ok "$target stopped." ;;
    obs)      _stop_obs; ok "Observability stopped." ;;
  esac
}

cmd_restart() {
  local target="${1:-}"

  # No arg: restart the whole VM
  if [[ -z "$target" ]]; then
    ensure_exists
    warn "Restarting VM..."
    orb stop "$VM_NAME" 2>/dev/null || true
    sleep 1
    orb start "$VM_NAME"
    sleep 2
    _start_obs
    ok "VM restarted."
    return
  fi

  # With arg: restart a specific stack
  ensure_running
  local resolved
  resolved=$(_resolve_stack "$target")
  case "$resolved" in
    static:*) vm_sudo systemctl reload nginx; ok "$target reloaded (Nginx)." ;;
    svc:*)    vm_sudo systemctl restart "${resolved#svc:}"; ok "$target restarted." ;;
    ctr:*)    vm_sudo docker restart "${resolved#ctr:}" 2>/dev/null; ok "$target restarted." ;;
    obs)      vm_sudo docker compose -f "$OBS_COMPOSE" restart 2>/dev/null; ok "Observability restarted." ;;
  esac
}

cmd_logs() {
  ensure_running
  local target="${1:-}"

  [[ -n "$target" ]] || die "Usage: devvm logs <stack|app|service>"

  local resolved
  resolved=$(_resolve_stack "$target")
  case "$resolved" in
    static:*) vm_sudo tail -f /var/log/nginx/access.log ;;
    svc:*)    vm_sudo journalctl -u "${resolved#svc:}" --no-pager -f ;;
    ctr:*)    vm_sudo docker logs -f "${resolved#ctr:}" 2>&1 ;;
    obs)      vm_sudo docker compose -f "$OBS_COMPOSE" logs -f --tail=50 ;;
  esac
}

cmd_reset() {
  local target="${1:-}"

  # No arg: full rebuild
  if [[ -z "$target" ]]; then
    ensure_exists
    warn "This will destroy and rebuild the entire VM."
    read -rp "Continue? (yes/no): " ans
    [[ "$ans" == "yes" ]] || { echo "Aborted."; return; }
    orb delete "$VM_NAME" -f 2>/dev/null || true
    sleep 2
    cmd_init
    return
  fi

  # With arg: reset a specific stack
  ensure_running
  local resolved
  resolved=$(_resolve_stack "$target")
  case "$resolved" in
    svc:mysql)
      vm_sudo mysql -u root -e "DROP USER IF EXISTS 'dev'@'%'; CREATE USER 'dev'@'%' IDENTIFIED BY 'dev'; GRANT ALL ON *.* TO 'dev'@'%' WITH GRANT OPTION; FLUSH PRIVILEGES;" 2>/dev/null
      vm_sudo systemctl restart mysql
      ok "MySQL reset (user: dev/dev)."
      ;;
    svc:postgresql)
      vm_sudo bash -c "sudo -u postgres psql -c \"ALTER USER dev WITH PASSWORD 'dev';\"" 2>/dev/null
      vm_sudo systemctl restart postgresql
      ok "PostgreSQL reset (user: dev/dev)."
      ;;
    svc:redis-server)
      vm_sudo bash -c "sed -i 's/^requirepass.*/# requirepass/' /etc/redis/redis.conf"
      vm_sudo systemctl restart redis-server
      ok "Redis reset (no password)."
      ;;
    obs)
      _stop_obs
      _start_obs
      ok "Observability restarted."
      ;;
    svc:*)
      vm_sudo systemctl restart "${resolved#svc:}"
      ok "$target restarted."
      ;;
    ctr:*)
      vm_sudo docker restart "${resolved#ctr:}" 2>/dev/null
      ok "$target restarted."
      ;;
  esac
}

cmd_ssh() {
  ensure_running
  if [[ $# -gt 0 ]]; then
    vm "$@"
  else
    vm
  fi
}

cmd_destroy() {
  ensure_exists
  echo -e "${R}${B}WARNING: This permanently deletes the VM and ALL its data.${N}"
  read -rp "Type 'destroy' to confirm: " ans
  [[ "$ans" == "destroy" ]] || { echo "Aborted."; return; }
  orb delete "$VM_NAME" -f
  ok "VM destroyed."
}

# ── Status ────────────────────────────────────────────────────────────────────

cmd_status() {
  ensure_orb

  if ! vm_exists; then
    echo -e "${R}VM does not exist. Run 'devvm init' to create.${N}"
    return
  fi

  echo -e "${B}DevVM${N} v${VERSION}"
  echo ""

  if ! vm_running; then
    echo -e "  State: ${R}stopped${N}"
    echo ""
    echo "  Run 'devvm start' to start."
    return
  fi

  echo -e "  State: ${G}running${N}"
  echo ""

  echo -e "${B}Languages${N}"
  local lang_ver
  lang_ver=$(vm bash -c 'export FNM_DIR="/usr/local/share/fnm"; eval "$(fnm env --shell bash 2>/dev/null)"; node --version 2>/dev/null || echo ""') || lang_ver=""
  [[ -n "$lang_ver" ]] && echo -e "  ${G}●${N} Node.js $lang_ver" || echo -e "  ${R}●${N} Node.js (not installed)"

  lang_ver=$(vm python3 --version 2>/dev/null | awk '{print $2}') || lang_ver=""
  [[ -n "$lang_ver" ]] && echo -e "  ${G}●${N} Python $lang_ver" || echo -e "  ${R}●${N} Python (not installed)"

  lang_ver=$(vm php -v 2>/dev/null | head -1 | awk '{print $2}') || lang_ver=""
  [[ -n "$lang_ver" ]] && echo -e "  ${G}●${N} PHP $lang_ver" || echo -e "  ${R}●${N} PHP (not installed)"

  lang_ver=$(vm bash -c 'export PATH="/usr/local/go/bin:$PATH"; go version 2>/dev/null' | awk '{print $3}') || lang_ver=""
  [[ -n "$lang_ver" ]] && echo -e "  ${G}●${N} Go ${lang_ver#go}" || echo -e "  ${R}●${N} Go (not installed)"

  lang_ver=$(vm bash -c 'source ~/.cargo/env 2>/dev/null; rustc --version 2>/dev/null' | awk '{print $2}') || lang_ver=""
  [[ -n "$lang_ver" ]] && echo -e "  ${G}●${N} Rust $lang_ver" || echo -e "  ${R}●${N} Rust (not installed)"

  lang_ver=$(vm java --version 2>/dev/null | head -1 | awk '{print $2}') || lang_ver=""
  [[ -n "$lang_ver" ]] && echo -e "  ${G}●${N} Java $lang_ver" || echo -e "  ${R}●${N} Java (not installed)"

  echo ""
  echo -e "${B}Databases${N}"
  for svc in mysql postgresql redis-server; do
    dot "$(svc_status "$svc")" "$svc"
  done

  echo ""
  echo -e "${B}Observability${N}"
  for ctr in grafana prometheus loki tempo promtail cadvisor; do
    local st
    st=$(vm_sudo docker inspect -f '{{.State.Status}}' "$ctr" 2>/dev/null) || st="not found"
    dot "$st" "$ctr"
  done

  # Show registered apps
  local apps_json
  apps_json=$(_apps_read 2>/dev/null) || apps_json='{"apps":{}}'
  local app_count
  app_count=$(echo "$apps_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('apps',{})))" 2>/dev/null) || app_count=0
  if [[ "$app_count" -gt 0 ]]; then
    echo ""
    echo -e "${B}Applications${N}"
    echo "$apps_json" | python3 -c "
import json, sys
d = json.load(sys.stdin)
for name in d.get('apps', {}):
    print(name)
" | while read -r aname; do
      dot "$(svc_status "app-${aname}" 2>/dev/null)" "$aname"
    done
  fi

  echo ""
  cmd_ports
}

# ── Open UIs ──────────────────────────────────────────────────────────────────

cmd_open() {
  local target="${1:-grafana}"
  local url=""

  case "$target" in
    grafana)    url="http://$HOST:3000" ;;
    adminer)    url="http://$HOST:8080" ;;
    prometheus) url="http://$HOST:9090" ;;
    loki)       url="http://$HOST:3100" ;;
    tempo)      url="http://$HOST:3200" ;;
    *)          die "Unknown UI: $target (grafana|adminer|prometheus|loki|tempo)" ;;
  esac

  info "Opening $url"
  open "$url"
}

# ── Debugging ─────────────────────────────────────────────────────────────────

cmd_debug() {
  ensure_running
  local lang="${1:-}"
  shift 2>/dev/null || true

  case "$lang" in
    python|py)
      info "debugpy on :5678 — attach VS Code 'Python: Remote Attach (dev VM)'"
      vm python-debug "$@"
      ;;
    node|js)
      info "Inspector on :9229 — attach VS Code 'Node: Remote Attach (dev VM)'"
      vm node-debug "$@"
      ;;
    php)
      echo -e "${C}Xdebug (trigger mode) on :9003${N}"
      echo ""
      echo "  Browser: add ?XDEBUG_TRIGGER=1 to URL"
      echo "  CLI:     XDEBUG_TRIGGER=1 php script.php"
      echo "  VS Code: use 'PHP: Xdebug (dev VM)' launch config"
      ;;
    go)
      info "Delve on :2345 — attach VS Code 'Go: Remote Attach (dev VM)'"
      vm go-debug "$@"
      ;;
    java)
      info "JDWP on :5005 — attach VS Code 'Java: Remote Attach (dev VM)'"
      vm java-debug "$@"
      ;;
    *)
      echo "Usage: devvm debug <language> [script] [args...]"
      echo ""
      echo "  python <file>   debugpy on :5678"
      echo "  node   <file>   Inspector on :9229"
      echo "  php             Xdebug instructions (:9003)"
      echo "  go     [pkg]    Delve on :2345"
      echo "  java   <class>  JDWP on :5005"
      ;;
  esac
}

# ── Databases ─────────────────────────────────────────────────────────────────

cmd_db() {
  ensure_running
  local db="${1:-}"
  shift 2>/dev/null || true

  # Read credentials from config (fallback to defaults)
  local creds
  creds=$(_creds_read 2>/dev/null) || creds='{}'
  local my_user my_pass pg_user pg_pass pg_db
  my_user=$(echo "$creds" | python3 -c "import json,sys; print(json.load(sys.stdin).get('mysql',{}).get('user','dev'))" 2>/dev/null) || my_user="dev"
  my_pass=$(echo "$creds" | python3 -c "import json,sys; print(json.load(sys.stdin).get('mysql',{}).get('pass','dev'))" 2>/dev/null) || my_pass="dev"
  pg_user=$(echo "$creds" | python3 -c "import json,sys; print(json.load(sys.stdin).get('postgres',{}).get('user','dev'))" 2>/dev/null) || pg_user="dev"
  pg_pass=$(echo "$creds" | python3 -c "import json,sys; print(json.load(sys.stdin).get('postgres',{}).get('pass','dev'))" 2>/dev/null) || pg_pass="dev"
  pg_db=$(echo "$creds" | python3 -c "import json,sys; print(json.load(sys.stdin).get('postgres',{}).get('db','devdb'))" 2>/dev/null) || pg_db="devdb"

  case "$db" in
    mysql)          vm mysql -u "$my_user" -p"$my_pass" "$@" ;;
    psql|postgres)
      local pg_args=""
      for arg in "$@"; do pg_args="$pg_args $(printf '%q' "$arg")"; done
      vm bash -c "PGPASSWORD='$pg_pass' psql -h 127.0.0.1 -U '$pg_user' '$pg_db' $pg_args"
      ;;
    redis)          vm redis-cli "$@" ;;
    *)
      echo "Usage: devvm db <mysql|psql|redis> [args...]"
      ;;
  esac
}

# ── Credentials ───────────────────────────────────────────────────────────────

_creds_read() {
  vm_sudo python3 -c "
import json, sys
with open('$VM_CONFIG/credentials.json') as f:
    print(json.dumps(json.load(f)))
" 2>/dev/null
}

_creds_write() {
  local json_str="$1"
  vm_sudo python3 -c "
import json
data = json.loads('$json_str')
with open('$VM_CONFIG/credentials.json', 'w') as f:
    json.dump(data, f, indent=2)
" 2>/dev/null
}

cmd_creds() {
  ensure_running
  local action="${1:-list}"
  shift 2>/dev/null || true

  case "$action" in
    list)
      local creds
      creds=$(_creds_read) || die "Cannot read credentials. Run 'devvm provision' first."
      echo -e "${B}Credentials${N}"
      echo ""
      echo "$creds" | python3 -c "
import json, sys
c = json.load(sys.stdin)
for name, info in c.items():
    parts = []
    if 'user' in info: parts.append(f\"user={info['user']}\")
    if 'pass' in info:
        p = info['pass']
        masked = p[:1] + '***' if p else '(none)'
        parts.append(f\"pass={masked}\")
    if 'db' in info: parts.append(f\"db={info['db']}\")
    if 'port' in info: parts.append(f\"port={info['port']}\")
    print(f'  {name:12s} {\"  \".join(parts)}')
"
      ;;

    show)
      local svc="${1:-}"
      [[ -n "$svc" ]] || die "Usage: devvm creds show <mysql|postgres|redis|grafana>"
      local creds
      creds=$(_creds_read) || die "Cannot read credentials."
      echo "$creds" | python3 -c "
import json, sys
c = json.load(sys.stdin)
name = '$svc'
if name not in c:
    print(f'Unknown service: {name}', file=sys.stderr); sys.exit(1)
info = c[name]
for k, v in info.items():
    print(f'  {k:8s} {v}')
"
      ;;

    set)
      local svc="${1:-}"
      shift 2>/dev/null || true
      [[ -n "$svc" ]] || die "Usage: devvm creds set <mysql|postgres|redis|grafana> --user X --pass Y [--db Z]"

      local user="" pass="" db=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user) user="$2"; shift 2 ;;
          --pass) pass="$2"; shift 2 ;;
          --db)   db="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done

      [[ -n "$user" || -n "$pass" || -n "$db" ]] || die "Provide --user, --pass, or --db"

      local creds
      creds=$(_creds_read) || die "Cannot read credentials."

      # Update JSON
      local updated
      updated=$(echo "$creds" | python3 -c "
import json, sys
c = json.load(sys.stdin)
name = '$svc'
if name not in c:
    print(json.dumps(c)); sys.exit(0)
if '$user': c[name]['user'] = '$user'
if '$pass': c[name]['pass'] = '$pass'
if '$db' and 'db' in c[name]: c[name]['db'] = '$db'
print(json.dumps(c))
")
      _creds_write "$updated"

      # Apply changes to actual services
      case "$svc" in
        mysql)
          local u="${user:-dev}" p="${pass:-dev}"
          vm_sudo mysql -u root -e "ALTER USER '${u}'@'%' IDENTIFIED BY '${p}';" 2>/dev/null || true
          vm_sudo mysql -u root -e "FLUSH PRIVILEGES;" 2>/dev/null || true
          ok "MySQL credentials updated."
          ;;
        postgres)
          local u="${user:-dev}" p="${pass:-dev}"
          vm_sudo bash -c "sudo -u postgres psql -c \"ALTER USER ${u} WITH PASSWORD '${p}';\"" 2>/dev/null || true
          ok "PostgreSQL credentials updated."
          ;;
        redis)
          if [[ -n "$pass" ]]; then
            vm_sudo bash -c "sed -i 's/^# requirepass.*/requirepass $pass/' /etc/redis/redis.conf; sed -i 's/^requirepass.*/requirepass $pass/' /etc/redis/redis.conf"
            vm_sudo systemctl restart redis-server 2>/dev/null || true
            ok "Redis password updated."
          fi
          ;;
        grafana)
          ok "Grafana credentials updated in config. Restart Grafana to apply: devvm obs restart grafana"
          ;;
      esac
      ;;

    reset)
      local svc="${1:-}"
      [[ -n "$svc" ]] || die "Usage: devvm creds reset <mysql|postgres|redis|grafana>"

      local defaults='{"mysql":{"user":"dev","pass":"dev","host":"127.0.0.1","port":3306,"db":"devdb"},"postgres":{"user":"dev","pass":"dev","host":"127.0.0.1","port":5432,"db":"devdb"},"redis":{"pass":"","host":"127.0.0.1","port":6379},"grafana":{"user":"admin","pass":"admin","port":3000}}'

      local creds
      creds=$(_creds_read) || die "Cannot read credentials."

      local updated
      updated=$(python3 -c "
import json
c = json.loads('$creds')
d = json.loads('$defaults')
name = '$svc'
if name in d: c[name] = d[name]
print(json.dumps(c))
")
      _creds_write "$updated"

      # Apply reset
      case "$svc" in
        mysql)
          vm_sudo mysql -u root -e "ALTER USER 'dev'@'%' IDENTIFIED BY 'dev'; FLUSH PRIVILEGES;" 2>/dev/null || true
          ;;
        postgres)
          vm_sudo bash -c "sudo -u postgres psql -c \"ALTER USER dev WITH PASSWORD 'dev';\"" 2>/dev/null || true
          ;;
        redis)
          vm_sudo bash -c "sed -i 's/^requirepass.*/# requirepass/' /etc/redis/redis.conf"
          vm_sudo systemctl restart redis-server 2>/dev/null || true
          ;;
      esac
      ok "$svc credentials reset to defaults."
      ;;

    *)
      echo "Usage: devvm creds <list|show|set|reset> [service] [flags]"
      echo ""
      echo "  list                         Show all credentials (masked)"
      echo "  show <service>               Show full credentials"
      echo "  set <service> --user X --pass Y [--db Z]"
      echo "  reset <service>              Reset to defaults"
      echo ""
      echo "Services: mysql, postgres, redis, grafana"
      ;;
  esac
}

# ── Applications ──────────────────────────────────────────────────────────────

_apps_read() {
  vm_sudo cat "$VM_CONFIG/apps.json" 2>/dev/null
}

_apps_write() {
  local json_str="$1"
  vm_sudo python3 -c "
import json
data = json.loads('''$json_str''')
with open('$VM_CONFIG/apps.json', 'w') as f:
    json.dump(data, f, indent=2)
" 2>/dev/null
}

_app_start_cmd() {
  local app_type="$1" port="$2" path="$3" custom_cmd="${4:-}"
  case "$app_type" in
    laravel)     echo "/usr/bin/php artisan serve --host=0.0.0.0 --port=$port" ;;
    wordpress)   echo "/usr/bin/php -S 0.0.0.0:$port" ;;
    django)      echo "/usr/bin/python3 manage.py runserver 0.0.0.0:$port" ;;
    flask)       echo "/usr/bin/python3 -m flask run --host=0.0.0.0 --port=$port" ;;
    fastapi)     echo "/usr/local/bin/uvicorn main:app --host 0.0.0.0 --port $port" ;;
    express)     echo "/usr/local/share/fnm/node-versions/v22.22.2/installation/bin/node app.js" ;;
    nextjs)      echo "/usr/local/share/fnm/node-versions/v22.22.2/installation/bin/npx next dev -p $port" ;;
    spring-boot) echo "/usr/bin/java -jar *.jar --server.port=$port" ;;
    go)          echo "/usr/local/go/bin/go run ." ;;
    static)      echo "" ;; # Nginx serves directly
    custom)      echo "$custom_cmd" ;;
    *)           echo "" ;;
  esac
}

cmd_app() {
  ensure_running
  local action="${1:-list}"
  shift 2>/dev/null || true

  case "$action" in
    add)
      local name="" path="" type="" port="" cmd_override=""
      # First positional arg is the name
      [[ $# -gt 0 && ! "$1" =~ ^-- ]] && { name="$1"; shift; }

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --path) path="$2"; shift 2 ;;
          --type) type="$2"; shift 2 ;;
          --port) port="$2"; shift 2 ;;
          --cmd)  cmd_override="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done

      [[ -n "$name" ]] || die "Usage: devvm app add <name> --path <dir> --type <type> [--port N] [--cmd 'custom command']"
      [[ -n "$path" ]] || die "Missing --path"
      [[ -n "$type" ]] || die "Missing --type (laravel|wordpress|django|flask|fastapi|express|nextjs|spring-boot|go|static|custom)"

      # Auto-assign port if not specified
      if [[ -z "$port" ]]; then
        local apps_json
        apps_json=$(_apps_read)
        port=$(echo "$apps_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('next_port', 8001))")
      fi

      info "Registering $name ($type) on port $port..."

      # Generate systemd service (skip for static — Nginx serves directly)
      local start_cmd
      start_cmd=$(_app_start_cmd "$type" "$port" "$path" "$cmd_override")

      if [[ -n "$start_cmd" ]]; then
        vm_sudo bash -c "cat > /etc/systemd/system/app-${name}.service << SVCEOF
[Unit]
Description=DevVM App: $name
After=network.target

[Service]
Type=simple
WorkingDirectory=$path
ExecStart=$start_cmd
Restart=always
RestartSec=5
Environment=PORT=$port
Environment=PATH=/usr/local/share/fnm/node-versions/v22.22.2/installation/bin:/usr/local/go/bin:/usr/local/bin:/usr/bin:/bin
Environment=FLASK_APP=app.py

[Install]
WantedBy=multi-user.target
SVCEOF"
        vm_sudo systemctl daemon-reload
        vm_sudo systemctl enable --now "app-${name}" 2>/dev/null || true
      fi

      # Generate Nginx vhost
      if [[ "$type" == "static" ]]; then
        vm_sudo bash -c "cat > /etc/nginx/sites-available/${name}.conf << NGXEOF
server {
    listen 80;
    server_name ${name}.dev.local;
    root $path;
    index index.html;
    location / { try_files \\\$uri \\\$uri/ =404; }
}
NGXEOF"
      else
        vm_sudo bash -c "cat > /etc/nginx/sites-available/${name}.conf << NGXEOF
server {
    listen 80;
    server_name ${name}.dev.local;
    location / {
        proxy_pass http://127.0.0.1:$port;
        proxy_set_header Host \\\$host;
        proxy_set_header X-Real-IP \\\$remote_addr;
        proxy_set_header X-Forwarded-For \\\$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \\\$scheme;
    }
}
NGXEOF"
      fi
      vm_sudo ln -sf "/etc/nginx/sites-available/${name}.conf" "/etc/nginx/sites-enabled/${name}.conf"
      vm_sudo nginx -t 2>/dev/null && vm_sudo systemctl reload nginx

      # Update apps.json
      local apps_json
      apps_json=$(_apps_read)
      local updated
      updated=$(echo "$apps_json" | python3 -c "
import json, sys
d = json.load(sys.stdin)
d['apps']['$name'] = {'path': '$path', 'type': '$type', 'port': $port}
d['next_port'] = max(d.get('next_port', 8001), $port + 1)
print(json.dumps(d))
")
      _apps_write "$updated"

      ok "$name registered and running."
      echo "  URL:  http://${name}.dev.local"
      echo "  Port: $port"
      ;;

    remove)
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: devvm app remove <name>"

      vm_sudo systemctl stop "app-${name}" 2>/dev/null || true
      vm_sudo systemctl disable "app-${name}" 2>/dev/null || true
      vm_sudo rm -f "/etc/systemd/system/app-${name}.service"
      vm_sudo systemctl daemon-reload 2>/dev/null || true
      vm_sudo rm -f "/etc/nginx/sites-available/${name}.conf" "/etc/nginx/sites-enabled/${name}.conf"
      vm_sudo systemctl reload nginx 2>/dev/null || true

      local apps_json
      apps_json=$(_apps_read)
      local updated
      updated=$(echo "$apps_json" | python3 -c "
import json, sys
d = json.load(sys.stdin)
d['apps'].pop('$name', None)
print(json.dumps(d))
")
      _apps_write "$updated"

      ok "$name removed."
      ;;

    list)
      local apps_json
      apps_json=$(_apps_read) || { echo "No apps registered."; return; }

      local count
      count=$(echo "$apps_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('apps',{})))")

      if [[ "$count" == "0" ]]; then
        echo "No apps registered. Use 'devvm app add' to register one."
        return
      fi

      echo -e "${B}Applications${N}"
      echo ""
      printf "  ${D}%-15s %-12s %-6s %-25s %s${N}\n" "NAME" "TYPE" "PORT" "URL" "STATUS"
      echo "$apps_json" | python3 -c "
import json, sys, subprocess
d = json.load(sys.stdin)
for name, info in d.get('apps', {}).items():
    print(f\"{name}|{info['type']}|{info['port']}|http://{name}.dev.local\")
" | while IFS='|' read -r aname atype aport aurl; do
        local st
        st=$(svc_status "app-${aname}" 2>/dev/null)
        local color="${G}"
        [[ "$st" == "active" ]] || color="${R}"
        printf "  %-15s %-12s %-6s %-25s ${color}%s${N}\n" "$aname" "$atype" "$aport" "$aurl" "$st"
      done
      ;;

    start|stop|restart)
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: devvm app $action <name>"
      vm_sudo systemctl "$action" "app-${name}"
      ok "$name: $action done."
      ;;

    logs)
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: devvm app logs <name>"
      vm_sudo journalctl -u "app-${name}" --no-pager -f
      ;;

    create)
      local name="" template=""
      [[ $# -gt 0 && ! "$1" =~ ^-- ]] && { name="$1"; shift; }
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --template|-t) template="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done

      [[ -n "$name" ]] || die "Usage: devvm app create <name> --template <type>"
      [[ -n "$template" ]] || die "Missing --template (laravel|django|flask|fastapi|express|nextjs|go-web|static|wordpress)"

      local target_path="$HOME/projects/$name"
      mkdir -p "$target_path"

      info "Scaffolding $name with $template..."

      case "$template" in
        laravel)
          vm bash -c "cd $(dirname "$target_path") && composer create-project laravel/laravel $name" || die "Laravel scaffold failed"
          ;;
        django)
          vm bash -c "cd $target_path && python3 -m django startproject $name ." || die "Django scaffold failed"
          ;;
        nextjs)
          vm bash -c "export PATH=/usr/local/share/fnm/node-versions/v22.22.2/installation/bin:\$PATH && cd $(dirname "$target_path") && npx create-next-app@latest $name --yes" || die "Next.js scaffold failed"
          ;;
        wordpress)
          vm bash -c "cd $target_path && curl -sO https://wordpress.org/latest.tar.gz && tar xzf latest.tar.gz --strip-components=1 && rm latest.tar.gz" || die "WordPress download failed"
          ;;
        flask|fastapi|express|go-web|static)
          # Copy built-in templates
          local tpl_dir
          tpl_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../provision/templates/$template"
          if [[ -d "$tpl_dir" ]]; then
            cp -r "$tpl_dir"/* "$target_path/"
            # Replace APP_NAME placeholder
            find "$target_path" -type f -exec sed -i '' "s/APP_NAME/$name/g" {} \; 2>/dev/null || true
          else
            die "Template not found: $template"
          fi
          # Install deps for node templates
          if [[ "$template" == "express" ]]; then
            vm bash -c "export PATH=/usr/local/share/fnm/node-versions/v22.22.2/installation/bin:\$PATH && cd $target_path && npm install" 2>/dev/null || true
          fi
          ;;
        *)
          die "Unknown template: $template"
          ;;
      esac

      ok "Created $name at $target_path"

      # Auto-register it
      local app_type="$template"
      [[ "$template" == "go-web" ]] && app_type="go"
      cmd_app add "$name" --path "$target_path" --type "$app_type"
      ;;

    *)
      echo "Usage: devvm app <add|remove|list|start|stop|restart|logs|create>"
      echo ""
      echo "  add <name> --path <dir> --type <type> [--port N]"
      echo "  remove <name>"
      echo "  list"
      echo "  start|stop|restart <name>"
      echo "  logs <name>"
      echo "  create <name> --template <type>"
      echo ""
      echo "Types: laravel, wordpress, django, flask, fastapi, express, nextjs, spring-boot, go, static, custom"
      echo ""
      echo "Templates (for create): laravel, django, flask, fastapi, express, nextjs, go-web, static, wordpress"
      ;;
  esac
}

# ── Run command in VM ─────────────────────────────────────────────────────────

cmd_run() {
  ensure_running
  [[ $# -gt 0 ]] || die "Usage: devvm run <command> [args...]"
  vm "$@"
}

cmd_exec() {
  ensure_running
  [[ $# -gt 0 ]] || die "Usage: devvm exec <command> [args...]"
  vm_sudo "$@"
}

# ── Ports ─────────────────────────────────────────────────────────────────────

cmd_ports() {
  echo -e "${B}Services${N}  (accessible at $HOST)"
  printf "  ${D}%-18s %-6s %s${N}\n" "NAME" "PORT" "ACCESS"
  printf "  %-18s %-6s %s\n" "Grafana"      3000 "http://$HOST:3000"
  printf "  %-18s %-6s %s\n" "Prometheus"   9090 "http://$HOST:9090"
  printf "  %-18s %-6s %s\n" "Loki"         3100 "http://$HOST:3100"
  printf "  %-18s %-6s %s\n" "Tempo"        3200 "grpc://$HOST:4317"
  printf "  %-18s %-6s %s\n" "Adminer"      8080 "http://$HOST:8080"
  printf "  %-18s %-6s %s\n" "MySQL"        3306 "dev/dev"
  printf "  %-18s %-6s %s\n" "PostgreSQL"   5432 "dev/dev (db: devdb)"
  printf "  %-18s %-6s %s\n" "Redis"        6379 "(no auth)"
  echo ""
  echo -e "${B}Debuggers${N}"
  printf "  ${D}%-18s %-6s %s${N}\n" "NAME" "PORT" "DIRECTION"
  printf "  %-18s %-6s %s\n" "Xdebug"       9003 "VM -> Mac"
  printf "  %-18s %-6s %s\n" "debugpy"      5678 "Mac -> VM"
  printf "  %-18s %-6s %s\n" "Node inspect" 9229 "Mac -> VM"
  printf "  %-18s %-6s %s\n" "Delve"        2345 "Mac -> VM"
  printf "  %-18s %-6s %s\n" "JDWP"         5005 "Mac -> VM"
}

# ── Verify ────────────────────────────────────────────────────────────────────

cmd_verify() {
  ensure_running
  vm_sudo bash "$VM_TARGET/verify.sh"
}

# ── Version ───────────────────────────────────────────────────────────────────

cmd_version() {
  echo "devvm $VERSION"
}

# ── Help ──────────────────────────────────────────────────────────────────────

cmd_help() {
  cat <<EOF
${B}devvm${N} v${VERSION} — Developer VM manager for OrbStack

${B}USAGE${N}
  devvm <command> [target]

${B}MACHINE${N}
  init                     Create VM and install everything (~5 min)
  destroy                  Delete VM permanently

${B}CONTROL${N}  ${D}— no target = whole VM, with target = just that stack${N}
  start [target]           Start VM or a stack
  stop [target]            Stop VM or a stack
  restart [target]         Restart VM or a stack
  reset [target]           Rebuild VM or reset a stack to defaults
  logs <target>            Tail logs for a stack or app

  ${D}Targets: mysql, postgres, redis, nginx, grafana, prometheus,
  loki, tempo, cadvisor, obs, or any app name${N}

${B}APPS${N}
  app add <name>           Register app  (--path, --type, [--port])
  app create <name>        Scaffold app  (--template)
  app list                 List all apps with status
  app remove <name>        Unregister and clean up

${B}DATA${N}
  db <mysql|psql|redis>    Connect to database shell
  creds                    List credentials (masked)
  creds show <service>     Show full credentials
  creds set <service>      Update credentials (--user, --pass, --db)
  creds reset <service>    Reset to defaults

${B}DEBUG${N}
  debug python <file>      debugpy on :5678
  debug node <file>        Node inspector on :9229
  debug php                Xdebug setup (trigger mode, :9003)
  debug go [pkg]           Delve on :2345
  debug java <class|jar>   JDWP on :5005

${B}VM ACCESS${N}
  ssh [command]            Shell into VM, or run one command
  run <cmd>                Run command as user
  exec <cmd>               Run command as root
  open <ui>                Open web UI (grafana|adminer|prometheus)

${B}INFO${N}
  status                   Show languages, databases, observability, apps
  ports                    Port map
  verify                   Health check (40 checks)
  version                  Show version
  help                     This help

${B}EXAMPLES${N}
  devvm init                            Create and provision
  devvm stop mysql                      Stop just MySQL
  devvm restart grafana                 Restart Grafana
  devvm logs redis                      Tail Redis logs
  devvm reset postgres                  Reset to dev/dev
  devvm app add blog --path ~/blog --type laravel
  devvm app create api -t fastapi       Scaffold + host
  devvm creds set mysql --pass secret   Change password
  devvm db psql                         PostgreSQL shell
  devvm debug python app.py             Start debugger

  ${D}Docs: https://github.com/indranandjha1993/devvm/tree/main/docs${N}
EOF
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)                 cmd_init "$@" ;;
    start|up)             cmd_start "$@" ;;
    stop|down)            cmd_stop "$@" ;;
    restart)              cmd_restart "$@" ;;
    reset)                cmd_reset "$@" ;;
    destroy)              cmd_destroy "$@" ;;
    logs)                 cmd_logs "$@" ;;
    ssh)                  cmd_ssh "$@" ;;
    run)                  cmd_run "$@" ;;
    exec)                 cmd_exec "$@" ;;
    open)                 cmd_open "$@" ;;
    status|st)            cmd_status "$@" ;;
    debug)                cmd_debug "$@" ;;
    db)                   cmd_db "$@" ;;
    creds)                cmd_creds "$@" ;;
    app)                  cmd_app "$@" ;;
    ports)                cmd_ports "$@" ;;
    verify)               cmd_verify "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       cmd_help ;;
    *)
      die "Unknown command: $cmd\nRun 'devvm help' for usage."
      ;;
  esac
}

main "$@"
